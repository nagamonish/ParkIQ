FROM node:20-alpine AS build

# Default to same-origin (the bundled nginx proxies /api + /ws to the cloud).
ARG VITE_CLOUD_URL=
ENV VITE_CLOUD_URL=$VITE_CLOUD_URL

WORKDIR /app
COPY sightline/package*.json ./
RUN npm install
COPY sightline ./
RUN npm run build

FROM nginx:1.27-alpine

COPY docker/nginx-sightline.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
